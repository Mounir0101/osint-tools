#!/bin/zsh
OSINT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$OSINT_DIR/recon-ng"
if [ ! -d ".venv" ]; then
  echo "[*] Installation Recon-ng..."
  python3 -m venv .venv
  source .venv/bin/activate
  pip install -r REQUIREMENTS -q
else
  source .venv/bin/activate
fi
if [ $# -eq 0 ]; then
  python3 recon-ng --help
else
  python3 recon-ng "$@"
fi
