#!/bin/zsh
OSINT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$OSINT_DIR/spiderfoot"
if [ ! -d ".venv" ]; then
  echo "[*] Installation Spiderfoot..."
  python3 -m venv .venv
  source .venv/bin/activate
  pip install -r requirements.txt -q
else
  source .venv/bin/activate
fi
if [ $# -eq 0 ]; then
  python3 sf.py --help
else
  python3 sf.py "$@"
fi
